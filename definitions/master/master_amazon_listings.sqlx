config {
  type: "table",
  schema: dataform.projectConfig.vars.master_dataset,
  description: "Master (latest-state) ‚Äî SKU MASTER: listing hi·ªán t·∫°i m·ªói SKU (SKU‚ÜîASIN‚Üîitem-name‚Üîstatus‚Üîgi√° m·ªõi nh·∫•t). Ngu·ªìn: stg_amazon_listings (snapshot theo ng√†y). Query 'hi·ªán t·∫°i' ƒë·ªçc b·∫£ng N√ÄY (1 d√≤ng/entity), kh·ªèi ph·∫£i MAX(snapshot_date) tr√™n staging. L·ªãch s·ª≠ ƒë·∫ßy ƒë·ªß v·∫´n ·ªü staging.",
  tags: ["master", "amazon", "listings"],
  bigquery: { clusterBy: ["seller_sku"] }
}

-- Latest-state: gi·ªØ d√≤ng M·ªöI NH·∫§T (theo snapshot_date) cho m·ªói seller_sku.
-- Nh·∫•t qu√°n v·ªõi h∆∞·ªõng B: m·ªçi domain ƒë·ªÅu c√≥ master tr·∫£ v·ªÅ TR·∫†NG TH√ÅI HI·ªÜN T·∫†I.
SELECT * EXCEPT(_rn)
FROM (
  SELECT
    s.*,
    ROW_NUMBER() OVER (
      PARTITION BY seller_sku
      ORDER BY snapshot_date DESC
    ) AS _rn
  FROM ${ref("stg_amazon_listings")} AS s
)
WHERE _rn = 1
